# =============================================================================
# Render.com — Production environment variables
# =============================================================================
#
# How to use:
#   1. Copy this file locally (optional):
#        cp .env.render.example .env.render
#   2. Fill in APP_KEY and APP_URL (see below).
#   3. In Render → Web Service → Environment → "Add from .env"
#      and upload `.env.render`, OR paste each variable manually.
#
# Generate APP_KEY locally:
#   php artisan key:generate --show
#
# APP_URL must match your Render service URL exactly, e.g.:
#   https://insider-one-champions-league.onrender.com
# =============================================================================

APP_NAME="Insider One Champions League"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR-SERVICE-NAME.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# SQLite (file inside the Docker container — no separate DB service needed)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=log

# Render sets PORT automatically; entrypoint uses it for `php artisan serve`
PORT=8080

# Set false — season is created on first visit via /api/league/state
SEED_ON_BOOT=false

VITE_APP_NAME="${APP_NAME}"
